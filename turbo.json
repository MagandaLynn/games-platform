{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "ENABLE_EXPERIMENTAL_COREPACK",
    "CLERK_SECRET_KEY",
    "DATABASE_URL",
    "DIRECT_URL"
  ],
  "tasks": {
    "lint": { "outputs": [] },
    "typecheck": { "outputs": [] },
    "test": { "outputs": [] },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": { "cache": false }
  }
}
