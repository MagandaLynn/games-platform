generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model HangmanDailyInstance {
  id        String        @id @default(cuid())
  date      DateTime
  mode      String
  puzzleId  String
  createdAt DateTime      @default(now())
  puzzle    HangmanPuzzle @relation(fields: [puzzleId], references: [id])
  plays     HangmanPlay[]

  @@unique([date, mode], name: "date_mode")
  @@index([mode, date])
}

model HangmanPlay {
  id           String  @id @default(cuid())
  instanceId   String
  sessionId    String
  userId       String?
  status       String  @default("playing")
  wrongGuesses Int     @default(0)
  guessed      String  @default("")

  hintUsed   Boolean   @default(false)
  hintUsedAt DateTime?

  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  instance  HangmanDailyInstance @relation(fields: [instanceId], references: [id])

  @@unique([instanceId, userId], name: "instance_user")
  @@unique([instanceId, sessionId], name: "instance_session")
  @@index([sessionId])
  @@index([userId])
}

model HangmanPuzzle {
  id              String                 @id @default(cuid())
  phrase          String
  hint            String?
  category        String?
  isDailyEligible Boolean                @default(false)
  createdAt       DateTime               @default(now())
  instances       HangmanDailyInstance[]
  dailySchedule   HangmanDailySchedule?

  savedBy SavedHangmanPuzzle[] // ✅ add this
}

model HangmanDailySchedule {
  id        String        @id @default(cuid())
  date      DateTime      @unique
  puzzleId  String        @unique
  createdAt DateTime      @default(now())
  puzzle    HangmanPuzzle @relation(fields: [puzzleId], references: [id])
}

model SavedHangmanPuzzle {
  id             String   @id @default(cuid())
  puzzleId       String
  userId         String?
  sessionId      String?
  savedAt        DateTime @default(now())
  lastInstanceId String?

  puzzle HangmanPuzzle @relation(fields: [puzzleId], references: [id])

  @@unique([puzzleId, userId], name: "puzzleId_userId")
  @@unique([puzzleId, sessionId], name: "puzzleId_sessionId")
  @@index([userId])
  @@index([sessionId])
}

// RPG Models
model RPGCharacter {
  id        String   @id @default(cuid())
  userId    String?
  sessionId String
  name      String
  level     Int      @default(1)
  xp        Int      @default(0)
  hp        Int      @default(100)
  maxHp     Int      @default(100)
  gold      Int      @default(0)
  
  // Stats
  strength     Int @default(10)
  defense      Int @default(10)
  intelligence Int @default(10)
  speed        Int @default(10)
  
  // Progress
  currentLocation String  @default("town")
  questsCompleted String  @default("[]") // JSON array of quest IDs
  inventory       String  @default("[]") // JSON array of items
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  battles   RPGBattle[]
  quests    RPGQuestProgress[]
  
  @@unique([sessionId])
  @@index([userId])
}

model RPGBattle {
  id          String   @id @default(cuid())
  characterId String
  enemyType   String
  result      String   // "won", "lost", "fled"
  xpGained    Int      @default(0)
  goldGained  Int      @default(0)
  damageDealt Int      @default(0)
  damageTaken Int      @default(0)
  turns       Int      @default(0)
  
  createdAt DateTime      @default(now())
  character RPGCharacter @relation(fields: [characterId], references: [id])
  
  @@index([characterId])
  @@index([createdAt])
}

model RPGQuestProgress {
  id          String   @id @default(cuid())
  characterId String
  questId     String
  status      String   @default("active") // "active", "completed", "failed"
  progress    String   @default("{}")     // JSON object for quest-specific progress
  
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  character RPGCharacter @relation(fields: [characterId], references: [id])
  
  @@unique([characterId, questId])
  @@index([characterId])
  @@index([status])
}

model WurpleDailyPlay {
  id          String   @id @default(cuid())
  seed        String
  date        DateTime
  mode        String
  sessionId   String
  userId      String?
  status      String   @default("playing")
  guessCount  Int      @default(0)
  maxGuesses  Int?
  won         Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([seed, mode, userId], name: "seed_mode_user")
  @@unique([seed, mode, sessionId], name: "seed_mode_session")
  @@index([mode, date])
  @@index([sessionId, date])
  @@index([userId, date])
}

model SemantleDailyPlay {
  id             String   @id @default(cuid())
  puzzleNumber   Int
  solved         Boolean  @default(false)
  guessCount     Int?
  topGuessNumber Int?
  topScore       Int?
  hintsUsed      Int?
  rawText        String
  sessionId      String
  userId         String?
  importedAt     DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([puzzleNumber, userId], name: "puzzle_user")
  @@unique([puzzleNumber, sessionId], name: "puzzle_session")
  @@index([sessionId, importedAt])
  @@index([userId, importedAt])
}

model SocialProfile {
  id          String   @id @default(cuid())
  handle      String   @unique
  displayName String?
  followToken String   @unique
  sessionId   String   @unique
  userId      String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  followers SocialFollow[] @relation("ProfileFollowers")
  following SocialFollow[] @relation("ProfileFollowing")
  blocks    SocialBlock[]  @relation("ProfileBlocks")
  blockedBy SocialBlock[]  @relation("ProfileBlockedBy")

  @@index([createdAt])
}

model SocialFollow {
  id                 String   @id @default(cuid())
  followerProfileId  String
  followingProfileId String
  createdAt          DateTime @default(now())

  follower  SocialProfile @relation("ProfileFollowing", fields: [followerProfileId], references: [id], onDelete: Cascade)
  following SocialProfile @relation("ProfileFollowers", fields: [followingProfileId], references: [id], onDelete: Cascade)

  @@unique([followerProfileId, followingProfileId], name: "follower_following")
  @@index([followerProfileId, createdAt])
  @@index([followingProfileId, createdAt])
}

model SocialBlock {
  id               String   @id @default(cuid())
  blockerProfileId String
  blockedProfileId String
  createdAt        DateTime @default(now())

  blocker SocialProfile @relation("ProfileBlocks", fields: [blockerProfileId], references: [id], onDelete: Cascade)
  blocked SocialProfile @relation("ProfileBlockedBy", fields: [blockedProfileId], references: [id], onDelete: Cascade)

  @@unique([blockerProfileId, blockedProfileId], name: "blocker_blocked")
  @@index([blockerProfileId, createdAt])
  @@index([blockedProfileId, createdAt])
}
